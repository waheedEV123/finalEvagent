# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Create these price IDs in your Stripe dashboard:
# Products → Add product → Add price (recurring/monthly)
STRIPE_STARTER_PRICE_ID=price_starter_id_from_stripe
STRIPE_PRO_PRICE_ID=price_pro_id_from_stripe
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_id_from_stripe

# ── App ────────────────────────────────────────────────────
# Your deployed Vercel URL (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
